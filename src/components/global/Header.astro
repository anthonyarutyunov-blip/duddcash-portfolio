---
import { SpecialText } from '../ui/special-text';
---

<header class="header">
  <div class="header__block">
    <a href="/" class="header__logo" transition:name="logo">
      <SpecialText client:load text="DUDDCASH STUDIO" speed={40} delay={0} />
    </a>
    <!-- Desktop nav (hidden on mobile) -->
    <nav class="header__nav">
      <a href="/#portfolio" class="header__nav-link">
        <SpecialText client:load text="Work" speed={25} delay={0.6} />
      </a>
      <a href="/about" class="header__nav-link">
        <SpecialText client:load text="About Us" speed={25} delay={0.8} />
      </a>
      <a href="/contact" class="header__nav-link">
        <SpecialText client:load text="Contact" speed={25} delay={1.0} />
      </a>
    </nav>
  </div>
</header>

<style is:global>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding: var(--space-lg) 3.9vw;
    pointer-events: none;
  }

  .header__logo {
    font-family: var(--font-display);
    font-size: max(1.1vw, 15px);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #111 !important;
    opacity: 1;
    filter: blur(0px);
    transition: color 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s var(--ease), filter 0.4s ease;
    pointer-events: auto;
  }

  .header--over-text .header__logo {
    filter: blur(1.5px);
    opacity: 0.45;
  }

  .header__logo span {
    color: inherit !important;
  }

  .header--light .header__logo {
    color: #fff !important;
  }

  .header__logo:hover {
    opacity: 0.6;
  }

  /* Nav block */
  .header__block {
    display: flex;
    flex-direction: column;
    gap: 0;
    pointer-events: auto;
  }

  .header__nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 6px;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.4s ease;
  }

  .header__nav-link {
    font-family: var(--font-display);
    font-size: max(0.75vw, 12px);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted) !important;
    text-decoration: none;
    transition: color 0.3s ease, opacity 0.6s var(--ease), filter 0.4s ease;
    line-height: 1.7;
    pointer-events: auto;
  }

  .header__nav-link span {
    color: inherit !important;
  }

  .header__nav-link:hover {
    color: var(--color-text) !important;
  }

  .header--light .header__nav-link {
    color: rgba(255,255,255,0.5) !important;
  }

  .header--light .header__nav-link:hover {
    color: #fff !important;
  }

  .header--over-text .header__nav {
    filter: blur(1.5px);
    opacity: 0.45;
  }

  /* Hide nav links when scrolled past hero */
  .header--nav-hidden .header__nav {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }

  /* Blur wordmark + nav over media content */
  .header--over-media .header__logo {
    filter: blur(2px);
    opacity: 0.35;
  }

  .header--over-media .header__nav {
    filter: blur(2px);
    opacity: 0.35;
  }

  /* ── Mobile styles ── */
  @media (max-width: 768px) {
    .header {
      padding: 14px 16px;
    }

    .header__logo {
      font-size: 13px;
    }

    .header__nav {
      gap: 1px;
      margin-top: 4px;
    }

    .header__nav-link {
      font-size: 10px;
      line-height: 1.6;
    }
  }
</style>

<script is:inline>
  (function() {
    var scrollHandler = null;

    function initHeaderColorSwitch() {
      var header = document.querySelector('.header');
      if (!header) return;

      // Clean up previous listeners from prior page
      if (scrollHandler) {
        window.removeEventListener('scroll', scrollHandler);
        window.removeEventListener('resize', scrollHandler);
      }

      var isMobileHeader = window.innerWidth <= 768 || 'ontouchstart' in window;

      function isDarkBg(el) {
        var bg = getComputedStyle(el).backgroundColor;
        if (bg === 'transparent' || bg === 'rgba(0, 0, 0, 0)') return false;
        var match = bg.match(/[\d.]+/g);
        if (!match || match.length < 3) return false;
        var r = Number(match[0]), g = Number(match[1]), b = Number(match[2]);
        if (match.length >= 4 && parseFloat(match[3]) < 0.1) return false;
        return (r * 0.299 + g * 0.587 + b * 0.114) < 60;
      }

      var lastState = null;
      var lastTextState = null;
      var lastNavHidden = null;
      var lastMediaState = null;

      // Use document.elementFromPoint instead of scanning every element
      function isOverText(logoRect) {
        var cx = (logoRect.left + logoRect.right) / 2;
        var cy = (logoRect.top + logoRect.bottom) / 2;
        var el = document.elementFromPoint(cx, cy);
        if (!el || el.closest('.header')) return false;
        var tag = el.tagName;
        return tag === 'H1' || tag === 'H2' || tag === 'H3' || tag === 'P' ||
               el.classList.contains('label') || el.classList.contains('stat__number') || el.classList.contains('stat__label');
      }

      function isOverMedia(logoRect) {
        var cx = (logoRect.left + logoRect.right) / 2;
        var cy = (logoRect.top + logoRect.bottom) / 2;
        var el = document.elementFromPoint(cx, cy);
        if (!el || el.closest('.header')) return false;
        var tag = el.tagName;
        return tag === 'IMG' || tag === 'VIDEO' || tag === 'PICTURE' || tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' ||
               el.classList.contains('gallery__item') || el.classList.contains('sticky-gallery__media') ||
               el.hasAttribute('data-media') || el.classList.contains('form-input') || el.closest('.contact__form');
      }

      // Cache section candidates — re-query only on page swap
      var darkCandidates = isMobileHeader ? null : document.querySelectorAll('.globe-section, .footer, section');

      // Mobile: lightweight check — only track hero visibility for nav toggle
      function checkMobile() {
        var hero = document.getElementById('hero');
        if (hero) {
          var heroBottom = hero.getBoundingClientRect().bottom;
          var navHidden = heroBottom < 0;
          if (lastNavHidden !== navHidden) {
            header.classList.toggle('header--nav-hidden', navHidden);
            lastNavHidden = navHidden;
          }
        }
      }

      // Desktop: full check — dark bg, nav hidden, text/media overlap
      function checkDesktop() {
        var checkY = 30;
        var overDark = false;
        for (var i = 0; i < darkCandidates.length; i++) {
          var rect = darkCandidates[i].getBoundingClientRect();
          if (rect.top <= checkY && rect.bottom >= checkY && isDarkBg(darkCandidates[i])) {
            overDark = true;
            break;
          }
        }
        if (lastState !== overDark) {
          header.classList.toggle('header--light', overDark);
          lastState = overDark;
        }

        // Check if scrolled past hero — hide nav links
        var hero = document.getElementById('hero');
        if (hero) {
          var heroBottom = hero.getBoundingClientRect().bottom;
          var navHidden = heroBottom < 0;
          if (lastNavHidden !== navHidden) {
            header.classList.toggle('header--nav-hidden', navHidden);
            lastNavHidden = navHidden;
          }
        }

        // Check if logo is over text or media
        var logo = header.querySelector('.header__logo');
        if (logo) {
          var logoRect = logo.getBoundingClientRect();
          var overText = !overDark && isOverText(logoRect);
          if (lastTextState !== overText) {
            header.classList.toggle('header--over-text', overText);
            lastTextState = overText;
          }

          var overMedia = !overDark && isOverMedia(logoRect);
          if (lastMediaState !== overMedia) {
            header.classList.toggle('header--over-media', overMedia);
            lastMediaState = overMedia;
          }
        }
      }

      var check = isMobileHeader ? checkMobile : checkDesktop;

      // RAF-throttled scroll listener instead of 200ms setInterval
      var rafPending = false;
      function onScrollOrResize() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(function() {
          check();
          rafPending = false;
        });
      }
      check();
      scrollHandler = onScrollOrResize;
      window.addEventListener('scroll', scrollHandler, { passive: true });
      window.addEventListener('resize', scrollHandler, { passive: true });
    }

    document.addEventListener('astro:before-swap', function() {
      document.body.style.overflow = '';
      if (scrollHandler) {
        window.removeEventListener('scroll', scrollHandler);
        window.removeEventListener('resize', scrollHandler);
      }
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderColorSwitch);
    } else {
      initHeaderColorSwitch();
    }
    document.addEventListener('astro:after-swap', initHeaderColorSwitch);
  })();
</script>

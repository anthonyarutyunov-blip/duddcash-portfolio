---
import { SpecialText } from '../ui/special-text';
---

<header class="header">
  <a href="/" class="header__logo" transition:name="logo">
    <SpecialText client:load text="DUDDCASH STUDIO" speed={40} delay={0} />
  </a>
</header>

<style is:global>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding: var(--space-lg) 3.9vw;
    pointer-events: none;
  }

  .header__logo {
    font-family: var(--font-display);
    font-size: max(0.85vw, 13px);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #111 !important;
    transition: color 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s var(--ease);
    pointer-events: auto;
  }

  .header__logo span {
    color: inherit !important;
  }

  .header--light .header__logo {
    color: #fff !important;
  }

  .header__logo:hover {
    opacity: 0.6;
  }
</style>

<script is:inline>
  (function() {
    var checkerId = null;

    function initHeaderColorSwitch() {
      var header = document.querySelector('.header');
      if (!header) return;

      // Clear any previous interval from prior page
      if (checkerId) clearInterval(checkerId);

      function isDarkBg(el) {
        var bg = getComputedStyle(el).backgroundColor;
        if (bg === 'transparent' || bg === 'rgba(0, 0, 0, 0)') return false;
        var match = bg.match(/[\d.]+/g);
        if (!match || match.length < 3) return false;
        var r = Number(match[0]), g = Number(match[1]), b = Number(match[2]);
        if (match.length >= 4 && parseFloat(match[3]) < 0.1) return false;
        return (r * 0.299 + g * 0.587 + b * 0.114) < 60;
      }

      var lastState = null;
      function check() {
        var checkY = 30;
        var overDark = false;
        var candidates = document.querySelectorAll('.globe-section, .footer, section');
        for (var i = 0; i < candidates.length; i++) {
          var rect = candidates[i].getBoundingClientRect();
          if (rect.top <= checkY && rect.bottom >= checkY && isDarkBg(candidates[i])) {
            overDark = true;
            break;
          }
        }
        if (lastState !== overDark) {
          header.classList.toggle('header--light', overDark);
          lastState = overDark;
        }
      }

      // Use rAF-based polling — works regardless of scroll method (Lenis, native, etc.)
      function loop() {
        check();
        requestAnimationFrame(loop);
      }
      requestAnimationFrame(loop);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderColorSwitch);
    } else {
      initHeaderColorSwitch();
    }
    document.addEventListener('astro:after-swap', initHeaderColorSwitch);
  })();
</script>

---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/#portfolio', label: 'Work' },
  { href: '/contact', label: 'Contact' },
];

const socialLinks = [
  { href: 'https://instagram.com/duddcash', label: 'Instagram' },
  { href: 'https://www.linkedin.com/in/anthony-arutyunov-0284a32a2/', label: 'LinkedIn' },
  { href: 'mailto:action@duddcashstudios.com', label: 'Email' },
  { href: 'https://patreon.com/DuddCash', label: 'Patreon' },
];

const baseCities = ['CHI', 'CLE'];
---

<footer class="footer">
  <div class="footer__glow"></div>

  <div class="footer__inner">
    <!-- Top section -->
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">DUDDCASH STUDIO</a>

        <div class="footer__location-row">
          <span class="footer__location-label">Based in</span>
          <span class="footer__arrow">&rarr;</span>
          {baseCities.map((city) => (
            <span class="footer__city-badge">{city}</span>
          ))}
        </div>

        <div class="footer__location-row">
          <span class="footer__location-label">Available Worldwide</span>
          <span class="footer__arrow">&rarr;</span>
          <span class="footer__globe-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </span>
        </div>
      </div>

      <div class="footer__links">
        <nav class="footer__nav-col">
          <span class="footer__col-title">Pages</span>
          {navLinks.map(({ href, label }) => (
            <a href={href} class="footer__nav-link">
              <span class="footer__link-text" data-text={label}>{label}</span>
            </a>
          ))}
        </nav>

        <nav class="footer__nav-col">
          <span class="footer__col-title">Connect</span>
          {socialLinks.map(({ href, label }) => (
            <a href={href} target="_blank" rel="noopener noreferrer" class="footer__nav-link footer__nav-link--external">
              <span class="footer__link-text" data-text={label}>{label}</span>
              <span class="footer__external-arrow">&nearr;</span>
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Wanna know more CTA -->
    <a href="/about" class="footer__cta-row">
      <span class="footer__cta-text">wanna know more?</span>
      <svg class="footer__cta-squiggle" viewBox="0 0 200 24" fill="none" preserveAspectRatio="none">
        <path d="M0 12 C 15 2, 30 22, 45 12 S 75 2, 90 12 S 120 22, 135 12 S 165 2, 180 12 S 195 18, 200 12" stroke="url(#squiggle-grad)" stroke-width="2" stroke-linecap="round" fill="none" />
        <defs>
          <linearGradient id="squiggle-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(80, 130, 255, 0.3)" />
            <stop offset="50%" stop-color="rgba(80, 130, 255, 0.8)" />
            <stop offset="100%" stop-color="rgba(120, 160, 255, 0.6)" />
          </linearGradient>
        </defs>
      </svg>
      <span class="footer__cta-circle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </span>
      <span class="footer__cta-label">about us</span>
    </a>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <span class="footer__copy">&copy; {currentYear} Duddcash Studio</span>
      <div class="footer__bottom-links">
        <a href="/privacy" class="footer__bottom-link">Privacy</a>
        <a href="/terms" class="footer__bottom-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    position: relative;
    background: #0b0b0b;
    color: #fff;
    padding: 80px 3.9vw 32px;
    overflow: hidden;
  }

  .footer__glow {
    position: absolute;
    bottom: -60%;
    left: 10%;
    width: 80%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgba(60, 100, 255, 0.18) 0%, rgba(60, 100, 255, 0.06) 40%, transparent 70%);
    pointer-events: none;
    filter: blur(80px);
    animation: footerGlowPulse 8s ease-in-out infinite alternate;
  }

  @keyframes footerGlowPulse {
    0% { opacity: 0.7; transform: scale(1); }
    100% { opacity: 1; transform: scale(1.05); }
  }

  .footer__inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    z-index: 1;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  /* Brand / left side */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw + 0.5rem, 1.8rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #fff;
    line-height: 1;
    margin-bottom: 12px;
    transition: opacity 0.3s ease;
  }

  .footer__logo:hover {
    opacity: 0.7;
  }

  .footer__location-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__location-label {
    white-space: nowrap;
  }

  .footer__arrow {
    color: rgba(255, 255, 255, 0.3);
  }

  .footer__city-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 10px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.8);
    text-transform: uppercase;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .footer__city-badge:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  .footer__globe-icon {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Links / right side */
  .footer__links {
    display: flex;
    gap: var(--space-3xl);
  }

  .footer__nav-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 120px;
  }

  .footer__col-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 4px;
  }

  .footer__nav-link {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    position: relative;
    overflow: hidden;
  }

  /* Text reveal hover effect */
  .footer__link-text {
    position: relative;
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__link-text::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 100%;
    color: #fff;
  }

  .footer__nav-link:hover .footer__link-text {
    transform: translateY(-100%);
  }

  .footer__external-arrow {
    font-size: 12px;
    opacity: 0.4;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .footer__nav-link:hover .footer__external-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  /* Wanna know more CTA row */
  .footer__cta-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: var(--space-xl) 0;
    margin-bottom: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.4s ease;
  }

  .footer__cta-row:hover {
    border-color: rgba(80, 130, 255, 0.2);
  }

  .footer__cta-text {
    font-size: 15px;
    font-style: italic;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    transition: color 0.3s ease;
    letter-spacing: 0.02em;
  }

  .footer__cta-row:hover .footer__cta-text {
    color: rgba(255, 255, 255, 0.7);
  }

  .footer__cta-squiggle {
    flex: 1;
    height: 24px;
    margin: 0 16px;
    opacity: 0.6;
    transition: opacity 0.4s ease;
  }

  .footer__cta-row:hover .footer__cta-squiggle {
    opacity: 1;
    animation: squiggleDash 0.6s ease forwards;
  }

  @keyframes squiggleDash {
    from { stroke-dashoffset: 300; }
    to { stroke-dashoffset: 0; }
  }

  .footer__cta-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(80, 130, 255, 0.15);
    border: 1.5px solid rgba(80, 130, 255, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(80, 130, 255, 0.9);
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: circlePulse 3s ease-in-out infinite;
  }

  .footer__cta-row:hover .footer__cta-circle {
    background: rgba(80, 130, 255, 0.25);
    border-color: rgba(80, 130, 255, 0.7);
    box-shadow: 0 0 20px rgba(80, 130, 255, 0.3), 0 0 40px rgba(80, 130, 255, 0.1);
    transform: scale(1.1);
    animation: none;
  }

  @keyframes circlePulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(80, 130, 255, 0.2); }
    50% { box-shadow: 0 0 0 8px rgba(80, 130, 255, 0); }
  }

  .footer__cta-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(80, 130, 255, 0.7);
    margin-left: 12px;
    white-space: nowrap;
    transition: color 0.3s ease;
  }

  .footer__cta-row:hover .footer__cta-label {
    color: rgba(120, 160, 255, 1);
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer__bottom-links {
    display: flex;
    gap: 20px;
  }

  .footer__bottom-link {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.3s ease;
  }

  .footer__bottom-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .footer {
      padding: 48px 20px 24px;
    }

    .footer__top {
      flex-direction: column;
      gap: var(--space-xl);
      padding-bottom: var(--space-xl);
    }

    .footer__links {
      gap: var(--space-xl);
    }

    .footer__nav-col {
      gap: 10px;
      min-width: 100px;
    }

    .footer__nav-link {
      font-size: 14px;
    }

    .footer__cta-row {
      flex-wrap: wrap;
      gap: 12px;
      padding: var(--space-lg) 0;
      margin-bottom: var(--space-md);
    }

    .footer__cta-squiggle {
      display: none;
    }

    .footer__bottom {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
      padding-top: var(--space-lg);
    }
  }
</style>

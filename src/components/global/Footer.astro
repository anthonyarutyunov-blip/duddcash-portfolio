---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://instagram.com/duddcash', label: 'Instagram' },
  { href: 'https://vimeo.com/duddcash', label: 'Vimeo' },
];
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <span class="footer__logo">DUDDCASH</span>
      <p class="footer__tagline">Video & Photography</p>
    </div>

    <nav class="footer__social" aria-label="Social links">
      {socialLinks.map(({ href, label }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="footer__social-link">
          {label}
        </a>
      ))}
    </nav>

    <p class="footer__copy">
      &copy; {currentYear} Duddcash. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-2xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
  }

  .footer__logo {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-xs);
  }

  .footer__social {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__social-link {
    font-size: var(--text-sm);
    color: var(--color-muted);
    letter-spacing: 0.03em;
    transition: color var(--transition-base);
  }

  .footer__social-link:hover {
    color: var(--color-text);
  }

  .footer__copy {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
</style>

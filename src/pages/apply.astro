---
// Unlisted client-application funnel page. Not linked from site nav,
// noindex via FunnelLayout. Reached only by direct link (emails, decks, bio).
// Design language = the main site: Waves hero, InfiniteGrid square texture,
// MagneticCTA, TrustedByCarousel logos, dark FeaturedWork bento, GlobeSection,
// holographic application card with GradientDots.
import FunnelLayout from '../layouts/FunnelLayout.astro';
import { Waves } from '../components/ui/wave-background';
import { ScrollIndicator } from '../components/ui/scroll-indicator';
import { MagneticCTA } from '../components/ui/magnetic-cta';
import { TextReveal } from '../components/ui/text-reveal';
import { ShimmerText } from '../components/ui/shimmer-text';
import { GradientDots } from '../components/ui/gradient-dots';
import { InfiniteGrid } from '../components/ui/the-infinite-grid';
import TrustedByCarousel from '../components/home/TrustedByCarousel';
import GlobeSection from '../components/home/GlobeSection';
import FeaturedWork from '../components/funnel/FeaturedWork';

// v1 hero film: Wynn "The Year of Excess" residency film.
// Swap to the studio VSL's Bunny video ID once filmed.
const FILM_VIDEO_ID = 'ba823cf7-8001-4ed9-bf4b-ba292ab1c4e4';
const BUNNY_CDN = 'vz-4fcbca30-3f7.b-cdn.net';
const filmPoster = `https://${BUNNY_CDN}/${FILM_VIDEO_ID}/thumbnail.jpg`;
const filmSrc = `https://${BUNNY_CDN}/${FILM_VIDEO_ID}/play_1080p.mp4`;

// Cal.com booking link. Qualified applicants see this calendar inline and
// book straight onto Anthony's Google Calendar (30 min, Cal Video).
const CAL_LINK = 'anthony-arutyunov-5zunxb/strategy-call';

const pillars = [
  {
    title: 'Cut the same night',
    body: 'Recaps delivered while the night is still live online. Speed is the difference between content and news.',
  },
  {
    title: 'Built for volume',
    body: 'One crew on a consistent cadence. A growing bank of content your brand owns, not a one-off delivery.',
  },
  {
    title: 'One cinematic identity',
    body: 'Every venue, every campaign, every post carries the same considered look. No more mismatched freelancers.',
  },
  {
    title: 'We come from this world',
    body: 'Hospitality, nightlife, culture. You are not training anyone. We already know where to stand.',
  },
];
---

<FunnelLayout
  title="Work With Us"
  description="Duddcash partners with a small number of brands to deliver a month of cinematic content, every month."
>
  <!-- ============ HERO ============ -->
  <section class="f-hero" id="hero">
    <Waves client:load strokeColor="rgba(100, 90, 80, 0.15)" backgroundColor="transparent" />
    <div class="f-hero__fade-bottom"></div>
    <div class="f-hero__content">
      <p class="f-eyebrow" data-animate>Duddcash Studio &middot; Content Partnerships</p>
      <h1 class="f-hero__headline" data-animate>
        Built for brands<br />that never go quiet.
      </h1>
      <p class="f-hero__sub" data-animate>
        We partner with a small number of hospitality groups, venues, and brands to plan,
        shoot, and deliver a month of cinematic content, every month.
      </p>
      <div class="f-hero__actions" data-animate>
        <MagneticCTA client:load href="#apply">Start the Conversation</MagneticCTA>
      </div>
      <ScrollIndicator client:load />
    </div>
  </section>

  <!-- ============ FILM ============ -->
  <section class="f-film" id="film">
    <div class="f-container">
      <div class="f-film__head" data-animate>
        <TextReveal
          client:visible
          text="The work speaks."
          staggerDelay={0.1}
          initialDelay={0.1}
          style={{
            fontFamily: 'var(--font-display)',
            fontSize: 'clamp(2rem, 4.5vw, 3.5rem)',
            fontWeight: 500,
            letterSpacing: '-0.025em',
            lineHeight: 1.1,
            color: 'var(--color-text)',
          }}
        />
      </div>
      <div class="f-player" id="player" data-animate>
        <img src={filmPoster} alt="Duddcash film still" class="f-player__poster" id="player-poster" loading="lazy" />
        <button class="f-player__play" id="player-play" aria-label="Play film">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        </button>
        <video
          class="f-player__video"
          id="player-video"
          src={filmSrc}
          poster={filmPoster}
          controls
          playsinline
          preload="none"
          style="display:none;"
        ></video>
      </div>
    </div>
  </section>

  <!-- ============ TRUSTED BY THE BEST (logos) ============ -->
  <TrustedByCarousel client:visible />

  <!-- ============ GRID ZONE: pillars → featured work → application ============ -->
  <div class="f-grid-zone">
    <div class="f-grid-zone__bg">
      <div class="f-grid-zone__fade-in"></div>
      <div class="f-grid-zone__fade-out"></div>
      <InfiniteGrid client:visible height="100%" speedX={0.3} speedY={0.3} spotlightSize={350} />
    </div>
    <div class="f-grid-zone__content">

      <!-- Pillars: connected flow -->
      <section class="f-pillars">
        <div class="f-container">
          <div class="f-pillars__head" data-animate>
            <ShimmerText
              client:visible
              duration={3}
              delay={0.2}
              style={{
                fontFamily: 'var(--font-display)',
                fontSize: 'clamp(2rem, 4vw, 3.5rem)',
                fontWeight: 500,
                letterSpacing: '-0.02em',
                lineHeight: 1.1,
                color: 'var(--color-text)',
              }}
            >
              What a partnership looks like.
            </ShimmerText>
            <p class="f-pillars__sub">One crew. One look. Every month. Here is how the engine runs.</p>
          </div>

          <div class="f-flow" data-animate-stagger>
            {pillars.map((p, i) => (
              <>
                <div class="f-flow__card">
                  <div class="f-flow__card-border" aria-hidden="true"></div>
                  <div class="f-flow__card-inner">
                    <h3 class="f-flow__title">{p.title}</h3>
                    <p class="f-flow__body">{p.body}</p>
                  </div>
                </div>
                {i < pillars.length - 1 && (
                  <div class="f-flow__arrow" aria-hidden="true">
                    <svg viewBox="0 0 40 24" fill="none">
                      <path class="f-flow__arrow-path" d="M2 12 H30 M24 5 L32 12 L24 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </div>
                )}
              </>
            ))}
          </div>
        </div>
      </section>

      <!-- Featured work: same format as the site's Our Work grid -->
      <div style="min-height: 400px;"><FeaturedWork client:load /></div>

      <!-- ============ APPLICATION (holographic card) ============ -->
      <section class="f-apply" id="apply">
        <div class="f-apply__card">
          <div class="f-apply__card-border" aria-hidden="true"></div>
          <div class="f-apply__card-inner">
            <div class="f-apply__dots" aria-hidden="true">
              <GradientDots
                client:visible
                dotSize={4}
                spacing={8}
                duration={25}
                backgroundColor="rgba(240, 238, 235, 0.85)"
                colors={[
                  'rgba(195, 185, 165, 0.9)',
                  'rgba(175, 190, 170, 0.8)',
                  'rgba(185, 175, 195, 0.7)',
                  'rgba(200, 185, 165, 0.85)',
                ]}
                style={{ opacity: 0.45 }}
              />
            </div>

            <div class="f-apply__content">
              <div class="f-apply__head" data-animate>
                <TextReveal
                  client:visible
                  text="Tell us about the brand."
                  staggerDelay={0.1}
                  initialDelay={0.1}
                  style={{
                    fontFamily: 'var(--font-display)',
                    fontSize: 'clamp(1.9rem, 4vw, 3.2rem)',
                    fontWeight: 500,
                    letterSpacing: '-0.025em',
                    lineHeight: 1.1,
                    color: 'var(--color-text)',
                  }}
                />
                <p class="f-apply__sub">
                  We take on a handful of new partners at a time, so each one gets our full
                  attention. This takes about two minutes.
                </p>
              </div>

              <!-- How it works: inline flow strip -->
              <div class="f-steps" data-animate aria-label="How it works">
                <div class="f-steps__item">
                  <span class="f-steps__name">Apply</span>
                  <span class="f-steps__desc">two minutes</span>
                </div>
                <span class="f-steps__arrow" aria-hidden="true">
                  <svg viewBox="0 0 32 12" fill="none"><path d="M0 6 H26 M21 1 L27 6 L21 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div class="f-steps__item">
                  <span class="f-steps__name">Strategy call</span>
                  <span class="f-steps__desc">thirty minutes</span>
                </div>
                <span class="f-steps__arrow" aria-hidden="true">
                  <svg viewBox="0 0 32 12" fill="none"><path d="M0 6 H26 M21 1 L27 6 L21 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div class="f-steps__item">
                  <span class="f-steps__name">First month live</span>
                  <span class="f-steps__desc">on your feed</span>
                </div>
              </div>

              <div class="f-progress" aria-hidden="true">
                <span class="f-progress__step is-active" data-progress="1">01 &middot; You</span>
                <span class="f-progress__line"></span>
                <span class="f-progress__step" data-progress="2">02 &middot; The brand</span>
                <span class="f-progress__line"></span>
                <span class="f-progress__step" data-progress="3">03 &middot; The call</span>
              </div>

              <form id="apply-form" novalidate>
                <p class="sr-only" aria-hidden="true">
                  <label>Leave this field empty: <input name="website-url" tabindex="-1" autocomplete="off" /></label>
                </p>

                <!-- STEP 1: contact -->
                <fieldset class="f-step" data-step="1">
                  <div class="f-form-row">
                    <div class="f-form-group">
                      <label class="f-label" for="af-name">Name *</label>
                      <input class="f-input" type="text" id="af-name" name="name" required autocomplete="name" placeholder="Your name" />
                    </div>
                    <div class="f-form-group">
                      <label class="f-label" for="af-company">Company / brand *</label>
                      <input class="f-input" type="text" id="af-company" name="company" required autocomplete="organization" placeholder="Brand or group" />
                    </div>
                  </div>
                  <div class="f-form-row">
                    <div class="f-form-group">
                      <label class="f-label" for="af-email">Email *</label>
                      <input class="f-input" type="email" id="af-email" name="email" required autocomplete="email" placeholder="you@company.com" />
                    </div>
                    <div class="f-form-group">
                      <label class="f-label" for="af-phone">Phone</label>
                      <input class="f-input" type="tel" id="af-phone" name="phone" autocomplete="tel" placeholder="Optional" />
                    </div>
                  </div>
                  <p class="f-error" id="err-1" role="alert" style="display:none;">Please fill in your name, brand, and a valid email.</p>
                  <div class="f-step__actions">
                    <button type="button" class="fm-btn" id="next-1">
                      <span class="fm-btn__border" aria-hidden="true"></span>
                      <span class="fm-btn__shimmer" aria-hidden="true"></span>
                      <span class="fm-btn__text">Continue</span>
                    </button>
                  </div>
                </fieldset>

                <!-- STEP 2: qualification -->
                <fieldset class="f-step" data-step="2" style="display:none;">
                  <div class="f-q">
                    <p class="f-label">What best describes you? *</p>
                    <div class="f-pills" role="radiogroup" data-field="business_type">
                      <button type="button" class="f-pill" data-value="Restaurant or hospitality group">Restaurant or hospitality group</button>
                      <button type="button" class="f-pill" data-value="Hotel or resort">Hotel or resort</button>
                      <button type="button" class="f-pill" data-value="Nightlife, events, or festivals">Nightlife, events, or festivals</button>
                      <button type="button" class="f-pill" data-value="Brand or business">Brand or business</button>
                      <button type="button" class="f-pill" data-value="Agency or other">Agency or other</button>
                    </div>
                  </div>
                  <div class="f-q">
                    <p class="f-label">Your role *</p>
                    <div class="f-pills" role="radiogroup" data-field="role">
                      <button type="button" class="f-pill" data-value="Owner or founder">Owner or founder</button>
                      <button type="button" class="f-pill" data-value="Marketing lead">Marketing lead</button>
                      <button type="button" class="f-pill" data-value="Other">Other</button>
                    </div>
                  </div>
                  <div class="f-q">
                    <p class="f-label">Monthly content budget *</p>
                    <div class="f-pills" role="radiogroup" data-field="budget">
                      <button type="button" class="f-pill" data-value="Under $3k">Under $3k</button>
                      <button type="button" class="f-pill" data-value="$3k to $5k">$3k to $5k</button>
                      <button type="button" class="f-pill" data-value="$5k to $10k">$5k to $10k</button>
                      <button type="button" class="f-pill" data-value="$10k+">$10k+</button>
                      <button type="button" class="f-pill" data-value="No budget yet">No budget yet</button>
                    </div>
                  </div>
                  <div class="f-q">
                    <p class="f-label">When would you want to start? *</p>
                    <div class="f-pills" role="radiogroup" data-field="timeline">
                      <button type="button" class="f-pill" data-value="As soon as possible">As soon as possible</button>
                      <button type="button" class="f-pill" data-value="In the next 1 to 3 months">In the next 1 to 3 months</button>
                      <button type="button" class="f-pill" data-value="Just exploring">Just exploring</button>
                    </div>
                  </div>
                  <div class="f-q">
                    <label class="f-label" for="af-notes">Anything we should know about the brand?</label>
                    <textarea class="f-input f-textarea" id="af-notes" name="notes" rows="3" placeholder="Venues, campaigns, what you have in mind. Optional."></textarea>
                  </div>
                  <p class="f-error" id="err-2" role="alert" style="display:none;">Please answer the four questions above.</p>
                  <div class="f-step__actions">
                    <button type="button" class="btn--text link-reveal f-back" id="back-2">Back</button>
                    <button type="button" class="fm-btn" id="next-2">
                      <span class="fm-btn__border" aria-hidden="true"></span>
                      <span class="fm-btn__shimmer" aria-hidden="true"></span>
                      <span class="fm-btn__text">Continue</span>
                    </button>
                  </div>
                </fieldset>

                <!-- STEP 3: booking / confirmation -->
                <fieldset class="f-step" data-step="3" style="display:none;">
                  <div class="f-booked">
                    <h3 class="f-booked__title">You're a fit.</h3>
                    <p class="f-apply__sub" id="booking-copy">
                      Application received. Anthony reviews every application personally, usually
                      the same day, and you'll get an email from anthony@duddcashstudios.com to
                      lock in a time for the call.
                    </p>
                    <div id="cal-embed"></div>
                    <div class="f-step__actions">
                      <a href="/apply/booked" class="fm-btn" id="finish-btn">
                        <span class="fm-btn__border" aria-hidden="true"></span>
                        <span class="fm-btn__shimmer" aria-hidden="true"></span>
                        <span class="fm-btn__text">Done</span>
                      </a>
                    </div>
                  </div>
                </fieldset>
              </form>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- ============ GLOBAL REACH + OUR GOAL ============ -->
  <GlobeSection client:visible />

  <section class="f-goal-zone">
    <svg class="f-goal-zone__grid" width="100%" height="100%" aria-hidden="true">
      <defs>
        <pattern id="apply-goal-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#apply-goal-grid)" />
    </svg>
    <div class="f-goal" data-animate>
      <div class="f-goal__content">
        <h2 class="f-goal__label">Our Goal</h2>
        <p class="f-goal__text">
          Our goal at DUDDCASH is, simply put, to tell engaging stories with riveting visuals.
          Whether your company wants a fast paced, action packed advertisement, or a subtle
          &ldquo;do more with less&rdquo; approach, we want to help YOU achieve it. Through
          Storyboarding, Directing, Shooting, and/or Editing, we can be the missing piece of
          your puzzle. With a vast catalog of content ranging from car rallies to restaurants
          and even festivals, we have and will do whatever it takes to get the job done right.
        </p>
        <div class="f-goal__cta" data-animate>
          <MagneticCTA client:visible href="#apply">Apply to Work With Us</MagneticCTA>
        </div>
      </div>
    </div>
  </section>
</FunnelLayout>

<style>
  /* ============ shared ============ */
  .f-container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 3.9vw;
  }

  .f-eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* ============ hero (mirrors homepage hero) ============ */
  .f-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 10vh 3.9vw 0;
  }

  .f-hero__fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
    z-index: 1;
  }

  .f-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    width: 100%;
  }

  .f-hero__headline {
    font-family: var(--font-display);
    font-size: max(6.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .f-hero__sub {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: #3a3a3a;
    max-width: 620px;
  }

  .f-hero__actions {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .f-hero__headline {
      font-size: max(9vw, 38px);
    }
  }

  /* ============ film ============ */
  .f-film {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .f-film__head {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .f-player {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #0e0e0e;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.35);
  }

  .f-player__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease), opacity 0.5s var(--ease);
  }

  .f-player:hover .f-player__poster {
    transform: scale(1.025);
  }

  .f-player__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.4s var(--ease), background 0.3s ease;
    z-index: 2;
  }

  .f-player__play svg {
    margin-left: 4px;
  }

  .f-player__play:hover {
    transform: translate(-50%, -50%) scale(1.08);
    background: #fff;
  }

  .f-player__play:focus-visible {
    outline: 2px solid #111;
    outline-offset: 3px;
  }

  .f-player__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ============ grid zone (square texture like homepage) ============ */
  .f-grid-zone {
    position: relative;
  }

  .f-grid-zone__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .f-grid-zone__fade-in {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 250px;
    background: linear-gradient(to bottom, var(--color-bg) 30%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  .f-grid-zone__fade-out {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(to top, var(--color-bg) 20%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  .f-grid-zone__content {
    position: relative;
    z-index: 1;
  }

  /* ============ pillars flow ============ */
  .f-pillars {
    padding: var(--space-3xl) 0;
  }

  .f-pillars__head {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .f-pillars__sub {
    color: var(--color-muted);
    font-size: var(--text-base);
    margin-top: var(--space-md);
    font-style: italic;
  }

  .f-flow {
    display: flex;
    align-items: stretch;
    gap: 6px;
  }

  .f-flow__card {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .f-flow__card-border {
    position: absolute;
    inset: -1.5px;
    border-radius: 18px;
    background: linear-gradient(
      135deg,
      rgba(180, 170, 150, 0.35) 0%,
      rgba(220, 210, 195, 0.15) 25%,
      rgba(160, 200, 220, 0.28) 50%,
      rgba(200, 180, 220, 0.2) 75%,
      rgba(210, 195, 170, 0.35) 100%
    );
    background-size: 300% 300%;
    animation: fBorderFlow 9s ease-in-out infinite;
  }

  @keyframes fBorderFlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .f-flow__card-inner {
    position: relative;
    height: 100%;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 17px;
    padding: clamp(20px, 2.2vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease);
  }

  .f-flow__card:hover .f-flow__card-inner {
    transform: translateY(-4px);
    box-shadow: 0 16px 44px -18px rgba(0, 0, 0, 0.25);
  }

  .f-flow__title {
    font-family: var(--font-display);
    font-size: clamp(17px, 1.4vw, 22px);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .f-flow__body {
    font-size: max(13px, 0.85vw);
    line-height: 1.6;
    color: #4a4a4a;
  }

  .f-flow__arrow {
    display: flex;
    align-items: center;
    flex: 0 0 34px;
    color: rgba(0, 0, 0, 0.3);
  }

  .f-flow__arrow svg {
    width: 100%;
  }

  .f-flow__arrow-path {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: fArrowDraw 2.4s var(--ease) infinite;
  }

  @keyframes fArrowDraw {
    0% { stroke-dashoffset: 60; opacity: 0; }
    35% { stroke-dashoffset: 0; opacity: 1; }
    75% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }

  @media (max-width: 900px) {
    .f-flow {
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
    }

    .f-flow__arrow {
      flex: none;
      justify-content: center;
      padding: 6px 0;
    }

    .f-flow__arrow svg {
      width: 24px;
      transform: rotate(90deg);
    }
  }

  /* ============ application: holographic card ============ */
  .f-apply {
    padding: var(--space-2xl) 3.9vw calc(var(--space-3xl) * 1.2);
    display: flex;
    justify-content: center;
  }

  .f-apply__card {
    position: relative;
    z-index: 1;
    max-width: 860px;
    width: 100%;
  }

  .f-apply__card-border {
    position: absolute;
    inset: -1.5px;
    border-radius: 28px;
    background: linear-gradient(
      135deg,
      rgba(180, 170, 150, 0.3) 0%,
      rgba(220, 210, 195, 0.15) 20%,
      rgba(160, 200, 220, 0.25) 40%,
      rgba(200, 180, 220, 0.2) 60%,
      rgba(180, 210, 200, 0.25) 80%,
      rgba(210, 195, 170, 0.3) 100%
    );
    background-size: 400% 400%;
    animation: fBorderFlow 10s ease-in-out infinite;
    z-index: 0;
  }

  .f-apply__card-inner {
    position: relative;
    z-index: 1;
    background: rgba(240, 238, 235, 0.42);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    border-radius: 27px;
    padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1.5rem, 4vw, 4rem);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.25) inset,
      0 1px 0 rgba(255, 255, 255, 0.35) inset,
      0 0 60px rgba(180, 170, 150, 0.2),
      0 30px 80px -20px rgba(0, 0, 0, 0.08);
  }

  .f-apply__dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 27px;
    overflow: hidden;
    pointer-events: none;
    transition: opacity 0.5s ease, filter 0.5s ease;
  }

  .f-apply__card:hover .f-apply__dots {
    opacity: 1 !important;
    filter: brightness(1.4) saturate(1.3);
  }

  .f-apply__content {
    position: relative;
    z-index: 2;
  }

  .f-apply__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .f-apply__sub {
    font-size: var(--text-base);
    color: #4a4a4a;
    line-height: 1.65;
    max-width: 540px;
  }

  /* how-it-works strip */
  .f-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 1.5vw, 18px);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .f-steps__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .f-steps__name {
    font-family: var(--font-display);
    font-size: clamp(13px, 1.1vw, 16px);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .f-steps__desc {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .f-steps__arrow {
    width: 30px;
    color: rgba(0, 0, 0, 0.35);
    flex-shrink: 0;
  }

  /* progress */
  .f-progress {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .f-progress__step {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #b0aea8;
    white-space: nowrap;
    transition: color 0.4s ease;
  }

  .f-progress__step.is-active {
    color: #111;
  }

  .f-progress__line {
    flex: 1;
    min-width: 24px;
    height: 1px;
    background: rgba(0, 0, 0, 0.15);
  }

  /* form */
  fieldset.f-step {
    border: none;
  }

  .f-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .f-form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .f-label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #555;
  }

  .f-input {
    font: inherit;
    font-size: max(16px, var(--text-base));
    padding: 13px 16px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.6);
    color: var(--color-text);
    transition: border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
    width: 100%;
  }

  .f-input::placeholder {
    color: #9a988f;
  }

  .f-input:focus {
    outline: none;
    border-color: #111;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
  }

  .f-textarea {
    resize: vertical;
    min-height: 84px;
  }

  .f-q {
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .f-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .f-pill {
    font-size: var(--text-base);
    padding: 11px 18px;
    min-height: 44px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 40px;
    background: rgba(255, 255, 255, 0.5);
    color: #333;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .f-pill:hover {
    border-color: #111;
    color: #111;
    background: rgba(255, 255, 255, 0.8);
  }

  .f-pill:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }

  .f-pill.is-selected {
    background: #111;
    border-color: #111;
    color: #fff;
  }

  .f-error {
    font-size: var(--text-sm);
    color: #a03020;
    margin-bottom: var(--space-md);
  }

  .f-step__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .f-back {
    color: var(--color-muted);
  }

  .f-booked {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .f-booked__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  /* magnetic form button (vanilla twin of MagneticCTA) */
  .fm-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 16px 36px;
    border-radius: 60px;
    background: rgba(0, 0, 0, 0.03);
    cursor: pointer;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition: background 0.4s ease, transform 0.2s ease;
    border: none;
    font: inherit;
  }

  .fm-btn:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  .fm-btn__border {
    position: absolute;
    inset: 0;
    border-radius: 60px;
    padding: 1.5px;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.15),
      rgba(0, 0, 0, 0.05),
      rgba(120, 100, 80, 0.3),
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.15)
    );
    background-size: 300% 300%;
    animation: fmBorderRotate 4s linear infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  @keyframes fmBorderRotate {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .fm-btn__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(200, 180, 140, 0.15) 45%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(200, 180, 140, 0.15) 55%,
      transparent 70%
    );
    background-size: 250% 100%;
    animation: fmShimmerSweep 2s ease-in-out infinite;
    border-radius: 60px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .fm-btn:hover .fm-btn__shimmer {
    opacity: 1;
  }

  @keyframes fmShimmerSweep {
    0% { background-position: 200% 0; }
    100% { background-position: -50% 0; }
  }

  .fm-btn__text {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(14px, 1vw, 16px);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ============ our goal (grid texture like the about page) ============ */
  .f-goal-zone {
    position: relative;
    padding: var(--space-3xl) 3.9vw;
    overflow: hidden;
  }

  .f-goal-zone__grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .f-goal {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .f-goal__content {
    max-width: 760px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .f-goal__label {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .f-goal__text {
    font-size: var(--text-base);
    line-height: 1.75;
    color: #3a3a3a;
  }

  .f-goal__cta {
    margin-top: var(--space-md);
  }

  /* ============ responsive ============ */
  @media (max-width: 768px) {
    .f-form-row {
      grid-template-columns: 1fr;
    }

    .f-progress__step {
      font-size: 11px;
    }

    .f-steps__arrow {
      width: 20px;
    }

    .f-apply {
      padding-left: 12px;
      padding-right: 12px;
    }

    .f-apply__card-inner {
      border-radius: 20px;
      padding: 1.75rem 1.1rem;
    }

    .f-apply__card-border {
      border-radius: 21px;
    }

    .f-apply__dots {
      border-radius: 20px;
    }
  }

  /* Safari: kill expensive effects (site-wide pattern) */
  :global(.safari) .f-apply__card-inner {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: rgba(240, 238, 235, 0.85);
  }

  :global(.safari) .f-apply__dots {
    display: none;
  }

  :global(.safari) .f-flow__card-inner {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: rgba(255, 255, 255, 0.8);
  }

  :global(.safari) .fm-btn__border,
  :global(.safari) .fm-btn__shimmer,
  :global(.safari) .f-flow__card-border,
  :global(.safari) .f-apply__card-border,
  :global(.safari) .f-flow__arrow-path {
    animation: none;
  }
</style>

<script is:inline define:vars={{ CAL_LINK }}>
  (function () {
    // ---------- video player ----------
    var playBtn = document.getElementById('player-play');
    var poster = document.getElementById('player-poster');
    var video = document.getElementById('player-video');
    if (playBtn && video && poster) {
      playBtn.addEventListener('click', function () {
        poster.style.display = 'none';
        playBtn.style.display = 'none';
        video.style.display = 'block';
        video.play();
      });
    }

    // ---------- magnetic pull on form buttons ----------
    document.querySelectorAll('.fm-btn').forEach(function (btn) {
      btn.addEventListener('mousemove', function (e) {
        var r = btn.getBoundingClientRect();
        var dx = (e.clientX - (r.left + r.width / 2)) * 0.18;
        var dy = (e.clientY - (r.top + r.height / 2)) * 0.18;
        btn.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
      });
      btn.addEventListener('mouseleave', function () {
        btn.style.transform = 'translate(0,0)';
      });
    });

    // ---------- lead identity + attribution ----------
    function uuid() {
      return 'xxxxxxxxyxxx4xxxx'.replace(/[xy]/g, function (c) {
        var r = (Math.random() * 16) | 0;
        var v = c === 'x' ? r : (r & 0x3) | 0x8;
        return v.toString(16);
      }) + Date.now().toString(36);
    }

    var leadId;
    try {
      leadId = localStorage.getItem('dc_lead_id');
      if (!leadId) {
        leadId = uuid();
        localStorage.setItem('dc_lead_id', leadId);
      }
    } catch (e) {
      leadId = uuid();
    }

    var params = new URLSearchParams(window.location.search);
    var attribution = {
      utm_source: params.get('utm_source') || '',
      utm_medium: params.get('utm_medium') || '',
      utm_content: params.get('utm_content') || '',
      utm_campaign: params.get('utm_campaign') || '',
      el: params.get('el') || '',
      referrer: document.referrer || '',
    };

    // ---------- form state ----------
    var form = document.getElementById('apply-form');
    if (!form) return;

    var answers = {};
    var contact = {};

    document.querySelectorAll('.f-pills').forEach(function (group) {
      var field = group.getAttribute('data-field');
      group.querySelectorAll('.f-pill').forEach(function (pill) {
        pill.addEventListener('click', function () {
          group.querySelectorAll('.f-pill').forEach(function (p) {
            p.classList.remove('is-selected');
          });
          pill.classList.add('is-selected');
          answers[field] = pill.getAttribute('data-value');
        });
      });
    });

    function showStep(n) {
      document.querySelectorAll('.f-step').forEach(function (s) {
        s.style.display = s.getAttribute('data-step') === String(n) ? 'block' : 'none';
      });
      document.querySelectorAll('.f-progress__step').forEach(function (p) {
        p.classList.toggle('is-active', Number(p.getAttribute('data-progress')) <= n);
      });
      var card = document.querySelector('.f-apply__card');
      if (card) card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function send(event, extra) {
      var payload = Object.assign(
        {
          lead_id: leadId,
          event: event,
          page: window.location.pathname,
          honeypot: form.querySelector('[name="website-url"]').value || '',
        },
        attribution,
        contact,
        answers,
        extra || {}
      );
      var body = JSON.stringify(payload);
      var url = '/.netlify/functions/capture-lead';
      var sent = false;
      try {
        if (navigator.sendBeacon) {
          sent = navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
        }
      } catch (e) {}
      if (!sent) {
        fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body, keepalive: true }).catch(function () {
          setTimeout(function () {
            fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body, keepalive: true }).catch(function () {});
          }, 1500);
        });
      }
    }

    // ---------- step 1 ----------
    document.getElementById('next-1').addEventListener('click', function () {
      var name = document.getElementById('af-name').value.trim();
      var company = document.getElementById('af-company').value.trim();
      var email = document.getElementById('af-email').value.trim();
      var phone = document.getElementById('af-phone').value.trim();
      var err = document.getElementById('err-1');
      var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email);
      if (!name || !company || !emailOk) {
        err.style.display = 'block';
        return;
      }
      err.style.display = 'none';
      contact = { name: name, company: company, email: email, phone: phone };
      send('partial');
      showStep(2);
    });

    // ---------- step 2 ----------
    document.getElementById('back-2').addEventListener('click', function () {
      showStep(1);
    });

    document.getElementById('next-2').addEventListener('click', function () {
      var err = document.getElementById('err-2');
      var required = ['business_type', 'role', 'budget', 'timeline'];
      var missing = required.some(function (f) {
        return !answers[f];
      });
      if (missing) {
        err.style.display = 'block';
        return;
      }
      err.style.display = 'none';
      answers.notes = document.getElementById('af-notes').value.trim();

      var lowBudget = answers.budget === 'Under $3k' || answers.budget === 'No budget yet';
      var exploring = answers.timeline === 'Just exploring';

      if (lowBudget || exploring) {
        send('disqualified');
        window.location.href = '/apply/not-yet';
        return;
      }

      send('qualified');
      showStep(3);
      initBooking();
    });

    // ---------- step 3: booking ----------
    function initBooking() {
      if (!CAL_LINK) return; // fallback copy already in the DOM

      var copy = document.getElementById('booking-copy');
      if (copy) copy.textContent = 'Pick a time that works. The call is thirty minutes with Anthony.';
      var finish = document.getElementById('finish-btn');
      if (finish) finish.style.display = 'none';

      // Cal.com official embed snippet
      (function (C, A, L) {
        var p = function (a, ar) { a.q.push(ar); };
        var d = C.document;
        C.Cal = C.Cal || function () {
          var cal = C.Cal, ar = arguments;
          if (!cal.loaded) {
            cal.ns = {}; cal.q = cal.q || [];
            d.head.appendChild(d.createElement('script')).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            var api = function () { p(api, arguments); };
            var namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === 'string') { cal.ns[namespace] = api; p(api, ar); } else p(cal, ar);
            return;
          }
          p(cal, ar);
        };
      })(window, 'https://app.cal.com/embed/embed.js', 'init');

      window.Cal('init', { origin: 'https://cal.com' });
      window.Cal('inline', {
        elementOrSelector: '#cal-embed',
        calLink: CAL_LINK,
        config: {
          name: contact.name || '',
          email: contact.email || '',
        },
      });
      window.Cal('on', {
        action: 'bookingSuccessful',
        callback: function () {
          send('booked');
          window.location.href = '/apply/booked?b=1';
        },
      });
    }
  })();
</script>

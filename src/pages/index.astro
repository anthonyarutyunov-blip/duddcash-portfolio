---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/home/ContactCTA.astro';
import { Waves } from '../components/ui/wave-background';
import { ScrollIndicator } from '../components/ui/scroll-indicator';
import StickyScrollGallery from '../components/home/StickyScrollGallery';
import PortfolioGrid from '../components/home/PortfolioGrid';
import { InfiniteGrid } from '../components/ui/the-infinite-grid';
import { IntroScreen } from '../components/ui/intro-screen';
---

<BaseLayout title="Home" description="Duddcash — Creative agency for brands, artists, and events.">
  <!-- Intro Screen -->
  <IntroScreen client:load />

  <!-- Hero -->
  <section class="hero" id="hero">
    <Waves client:load strokeColor="rgba(100, 90, 80, 0.15)" backgroundColor="transparent" />
    <div class="hero__fade-bottom"></div>
    <div class="hero__content">
      <h1 class="hero__headline">
        The work speaks,<br />so we don't have to.
      </h1>
      <ScrollIndicator client:load />
    </div>

  </section>

  <!-- Infinite Grid starts right after hero, wraps all remaining content -->
  <div class="grid-section">
    <div class="grid-section__bg">
      <div class="grid-section__fade-in"></div>
      <div class="grid-section__fade-out"></div>
      <InfiniteGrid client:visible height="100%" speedX={0.3} speedY={0.3} spotlightSize={350} />
    </div>
    <div class="grid-section__content">
      <div style="min-height: 300px;"><StickyScrollGallery client:visible /></div>
      <div style="min-height: 400px;"><PortfolioGrid client:visible /></div>
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 3.9vw;
    padding-top: 10vh;
  }

  .hero__fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    width: 100%;
    max-width: 100%;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: max(6.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .hero__sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    font-style: italic;
    margin-top: calc(var(--space-md) * -0.5);
  }

  /* Staggered entrance after intro — only when intro played
     Intro: 5s loading + 0.25s pause + 0.15s flash + 0.9s settle ≈ 6.3s */
  .hero--with-intro .hero__headline {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 5.6s forwards;
  }

  .hero--with-intro .hero__sub {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 5.9s forwards;
  }

  .hero--with-intro .hero__scroll-indicator {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 6.2s forwards;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero__headline {
      font-size: max(9vw, 38px);
    }
  }

  .grid-section {
    position: relative;
  }

  .grid-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .grid-section__fade-in {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 250px;
    background: linear-gradient(to bottom, var(--color-bg) 30%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  .grid-section__fade-out {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(to top, var(--color-bg) 20%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  .grid-section__content {
    position: relative;
    z-index: 1;
  }
</style>

<script is:inline>
  // Deep-link from a shared video: if ?project=X (or &video=Y) is in the URL,
  // the user came from a shared link and should land directly on the portfolio
  // section with the project expanded. Skip the intro and jump to #portfolio
  // so PortfolioGrid (client:visible) hydrates and runs its URL-param handler.
  (function() {
    try {
      var params = new URLSearchParams(window.location.search);
      if (params.has("project")) {
        // Skip intro for shared links — set both flags so IntroScreen bails out
        sessionStorage.setItem("duddcash_visited", "1");
        sessionStorage.setItem("duddcash_nav", "1");

        // Jump to the portfolio section as soon as it's in the DOM.
        // #portfolio is server-rendered (inside PortfolioGrid), so it exists
        // before hydration. Scrolling there triggers client:visible hydration,
        // which then runs the expand-and-scroll-to-video logic.
        var tryScroll = function() {
          var el = document.getElementById("portfolio");
          if (el) {
            // Disable the default intro hero class — we're skipping the intro
            var hero = document.getElementById("hero");
            if (hero) hero.classList.remove("hero--with-intro");
            // Instant scroll to the portfolio section (no smooth — we don't
            // want a long scroll animation before the expand+video-scroll).
            el.scrollIntoView({ behavior: "instant", block: "start" });
            // Nudge up a bit to keep the filter bar visible under any sticky header
            window.scrollBy(0, -40);
            return true;
          }
          return false;
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", function() {
            if (!tryScroll()) {
              // Fallback: poll briefly in case #portfolio renders slightly late
              var tries = 0;
              var iv = setInterval(function() {
                if (tryScroll() || ++tries > 20) clearInterval(iv);
              }, 50);
            }
          });
        } else {
          tryScroll();
        }
        return; // Skip the standard intro logic below
      }
    } catch (e) {}

    // Normal flow: play intro on first visit or refresh, skip on nav.
    // "duddcash_nav" is set by a click listener on internal links (in BaseLayout).
    // On refresh no click happens, so the flag is absent → intro plays.
    var hero = document.getElementById("hero");
    if (!hero) return;
    var visited = sessionStorage.getItem("duddcash_visited");
    var cameFromNav = sessionStorage.getItem("duddcash_nav");
    if (!visited || !cameFromNav) {
      hero.classList.add("hero--with-intro");
    }
  })();
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import CinematicText from '../components/home/CinematicText.astro';
import ContactCTA from '../components/home/ContactCTA.astro';
import { Waves } from '../components/ui/wave-background';
import { LiquidLink } from '../components/ui/liquid-glass-button';
import MacFileWindow from '../components/ui/mac-file-window';
import { SpecialText } from '../components/ui/special-text';
import StickyScrollGallery from '../components/home/StickyScrollGallery';
import PortfolioGrid from '../components/home/PortfolioGrid';
import { InfiniteGrid } from '../components/ui/the-infinite-grid';
---

<BaseLayout title="Home" description="Duddcash — Creative agency for brands, artists, and events.">
  <!-- Hero -->
  <section class="hero">
    <Waves client:load strokeColor="rgba(100, 90, 80, 0.15)" backgroundColor="transparent" />
    <div class="hero__fade-bottom"></div>
    <div class="hero__content">
      <h1 class="hero__headline">
        <SpecialText client:load text="The work speaks so" speed={30} delay={0.7} />
        <br />
        <SpecialText client:load text="we don't have to." speed={30} delay={0.9} />
      </h1>
      <p class="hero__sub">
        <SpecialText client:load text="for brands that move fast" speed={25} delay={1.9} />
      </p>
      <div class="hero__cta">
        <LiquidLink client:load href="#portfolio" size="lg">See the Work</LiquidLink>
        <LiquidLink client:load href="/contact" size="lg">Start a Project</LiquidLink>
      </div>
    </div>

  </section>

  <MacFileWindow client:load />

  <!-- Infinite Grid starts right after hero, wraps all remaining content -->
  <div class="grid-section">
    <div class="grid-section__bg">
      <div class="grid-section__fade-in"></div>
      <InfiniteGrid client:visible height="100%" speedX={0.3} speedY={0.3} spotlightSize={350} />
    </div>
    <div class="grid-section__content">
      <StickyScrollGallery client:visible />
      <CinematicText />
      <PortfolioGrid client:visible />
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 3.9vw;
  }

  .hero__fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: max(6.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .hero__sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    font-style: italic;
    margin-top: calc(var(--space-md) * -0.5);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-md);
    opacity: 0;
    animation: heroCtaIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 4.3s forwards;
  }

  @keyframes heroCtaIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero__headline {
      font-size: max(9vw, 38px);
    }
  }

  .grid-section {
    position: relative;
  }

  .grid-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .grid-section__fade-in {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to bottom, var(--color-bg), transparent);
    z-index: 1;
    pointer-events: none;
  }

  .grid-section__content {
    position: relative;
    z-index: 1;
  }
</style>

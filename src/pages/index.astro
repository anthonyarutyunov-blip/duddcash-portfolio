---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/home/ContactCTA.astro';
import { Waves } from '../components/ui/wave-background';
import { LiquidLink } from '../components/ui/liquid-glass-button';
import MacFileWindow from '../components/ui/mac-file-window';
import { ScrollIndicator } from '../components/ui/scroll-indicator';
import StickyScrollGallery from '../components/home/StickyScrollGallery';
import PortfolioGrid from '../components/home/PortfolioGrid';
import { InfiniteGrid } from '../components/ui/the-infinite-grid';
import { IntroScreen } from '../components/ui/intro-screen';
---

<BaseLayout title="Home" description="Duddcash — Creative agency for brands, artists, and events.">
  <!-- Intro Screen -->
  <IntroScreen client:load />

  <!-- Hero -->
  <section class="hero" id="hero">
    <Waves client:load strokeColor="rgba(100, 90, 80, 0.15)" backgroundColor="transparent" />
    <div class="hero__fade-bottom"></div>
    <div class="hero__content">
      <h1 class="hero__headline">
        The work speaks so<br />we don't have to.
      </h1>
      <p class="hero__sub">
        for brands that move fast
      </p>
      <div class="hero__cta">
        <LiquidLink client:load href="/contact" size="lg">Start a Project</LiquidLink>
      </div>
      <ScrollIndicator client:load />
    </div>

  </section>

  <MacFileWindow client:load />

  <!-- Infinite Grid starts right after hero, wraps all remaining content -->
  <div class="grid-section">
    <div class="grid-section__bg">
      <div class="grid-section__fade-in"></div>
      <InfiniteGrid client:visible height="100%" speedX={0.3} speedY={0.3} spotlightSize={350} />
    </div>
    <div class="grid-section__content">
      <StickyScrollGallery client:visible />
      <PortfolioGrid client:visible />
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    text-align: center;
    padding: 0 3.9vw;
    padding-bottom: 8vh;
  }

  .hero__fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    pointer-events: none;
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: max(6.5vw, 48px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .hero__sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    font-style: italic;
    margin-top: calc(var(--space-md) * -0.5);
  }

  .hero__cta {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
  }

  /* Staggered entrance after intro — only when intro played
     Intro: 5s loading + 0.25s pause + 0.15s flash + 0.9s settle ≈ 6.3s */
  .hero--with-intro .hero__headline {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 5.6s forwards;
  }

  .hero--with-intro .hero__sub {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 5.9s forwards;
  }

  .hero--with-intro .hero__cta {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 6.2s forwards;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero__headline {
      font-size: max(9vw, 38px);
    }
  }

  .grid-section {
    position: relative;
  }

  .grid-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .grid-section__fade-in {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 250px;
    background: linear-gradient(to bottom, var(--color-bg) 30%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  .grid-section__content {
    position: relative;
    z-index: 1;
  }
</style>

<script is:inline>
  // Match IntroScreen logic: play on first visit or refresh, skip on navigation.
  // "duddcash_nav" is set by a click listener on internal links (in BaseLayout).
  // On refresh no click happens, so the flag is absent → intro plays.
  (function() {
    var hero = document.getElementById("hero");
    if (!hero) return;
    var visited = sessionStorage.getItem("duddcash_visited");
    var cameFromNav = sessionStorage.getItem("duddcash_nav");
    if (!visited || !cameFromNav) {
      hero.classList.add("hero--with-intro");
    }
  })();
</script>

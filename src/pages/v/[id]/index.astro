---
// Per-project share pages with proper OG meta + redirect to expanded homepage view.
// Used when someone shares a video link — generates proper link previews
// (project title + thumbnail) for iMessage, Slack, Twitter, etc.
// On actual page load, redirects to /?project={id} (+ optional &video= / &folder=).
//
// Paths come from BOTH base portfolio data AND editor-added projects stored in
// the published layout overrides (newProjects) — otherwise share links to
// anything Anthony adds through the site editor would 404.
// Content edits (renamed titles, custom thumbnails) are applied so the link
// preview matches what's live on the site.
import { portfolioItems, type PortfolioItem } from '../../../data/portfolio';
import { thumbnailUrl } from '../../../lib/bunny';
import overrides from '../../../data/layout-overrides.json';

interface ShareMeta {
  id: string;
  title: string;
  description: string;
  /** Custom thumbnail path/URL if set, else empty */
  customThumbnail: string;
  /** Video id (or player URL — thumbnailUrl normalizes) for CDN thumbnail fallback */
  thumbVideoId: string;
}

export async function getStaticPaths() {
  const contentEdits: { itemId: string; field: string; value: string }[] =
    (overrides as any).contentEdits || [];
  const editFor = (id: string, field: string): string | undefined =>
    contentEdits.find((e) => e.itemId === id && e.field === field)?.value;

  function getThumbnailVideoId(item: PortfolioItem): string {
    if (item.type === 'single') return item.video.videoId;
    if (item.thumbnailVideoId) return item.thumbnailVideoId;
    if (item.sections && item.sections.length > 0) {
      const firstSectionVideo = item.sections[0].videos[0];
      if (firstSectionVideo) return firstSectionVideo.videoId;
    }
    if (item.videos && item.videos.length > 0) return item.videos[0].videoId;
    return '';
  }

  // Base items — with content edits applied so previews match the live site
  const baseMetas: ShareMeta[] = portfolioItems.map((item) => ({
    id: item.id,
    title: editFor(item.id, 'title') ?? item.title,
    description:
      editFor(item.id, 'description') ?? item.description ?? '',
    customThumbnail:
      editFor(item.id, 'customThumbnail') ?? item.customThumbnail ?? '',
    thumbVideoId: getThumbnailVideoId(item),
  }));

  // Editor-added projects from the published layout file
  const baseIds = new Set(portfolioItems.map((i) => i.id));
  const newMetas: ShareMeta[] = ((overrides as any).newProjects || [])
    .filter((np: any) => !baseIds.has(np.id))
    .map((np: any) => ({
      id: np.id,
      title: editFor(np.id, 'title') ?? np.title,
      description: editFor(np.id, 'description') ?? np.description ?? '',
      customThumbnail:
        editFor(np.id, 'customThumbnail') ?? np.customThumbnail ?? '',
      thumbVideoId: np.videoId ?? '',
    }));

  return [...baseMetas, ...newMetas].map((meta) => ({
    params: { id: meta.id },
    props: { meta },
  }));
}

interface Props {
  meta: ShareMeta;
}

const { meta } = Astro.props;

// Prefer custom thumbnail if set (absolute URL), otherwise use Bunny CDN thumbnail
const ogImage = meta.customThumbnail
  ? (meta.customThumbnail.startsWith('http')
      ? meta.customThumbnail
      : new URL(meta.customThumbnail, Astro.site).href)
  : (meta.thumbVideoId
      ? thumbnailUrl(meta.thumbVideoId)
      : new URL('/og-image.jpg', Astro.site).href);

const title = `${meta.title} | Duddcash Studios`;
const description =
  meta.description ||
  `Watch ${meta.title} — video production by Duddcash Studios.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph — video preview -->
    <meta property="og:type" content="video.other" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="720" />
    <meta property="og:site_name" content="Duddcash Studios" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <style>
      html, body {
        margin: 0;
        padding: 0;
        background: #f2f2f2;
        color: #111;
        font-family: system-ui, -apple-system, sans-serif;
        height: 100%;
        width: 100%;
      }
      .loader {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        gap: 12px;
        opacity: 0.7;
      }
      .loader__title {
        font-weight: 500;
        letter-spacing: 0.04em;
        font-size: 14px;
        text-transform: uppercase;
      }
      .loader__sub {
        font-size: 12px;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="loader">
      <div class="loader__title">Loading {meta.title}</div>
      <div class="loader__sub">duddcashstudios.com</div>
    </div>

    <script define:vars={{ projectId: meta.id }}>
      // Redirect to homepage with project (and optional video/folder) params.
      // Client-side for speed; also has <noscript> fallback below.
      (function () {
        try {
          const urlParams = new URLSearchParams(window.location.search);
          const videoId = urlParams.get('video');
          const folder = urlParams.get('folder');
          let target = `/?project=${encodeURIComponent(projectId)}`;
          if (videoId) target += `&video=${encodeURIComponent(videoId)}`;
          if (folder) target += `&folder=${encodeURIComponent(folder)}`;
          window.location.replace(target);
        } catch (e) {
          window.location.replace('/');
        }
      })();
    </script>

    <!-- No-JS fallback: meta refresh to homepage with project param -->
    <noscript>
      <meta http-equiv="refresh" content={`0;url=/?project=${meta.id}`} />
    </noscript>
  </body>
</html>

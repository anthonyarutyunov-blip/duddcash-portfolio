---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about Duddcash — the story behind the lens.">
  <section class="about section container">
    <div class="about__content" data-animate>
      <h1>About</h1>
      <div class="about__text">
        <p>
          Duddcash is a video and photography studio built on a simple idea: every project
          deserves the same level of craft and attention, whether it's a wedding, a brand
          campaign, or a music video.
        </p>
        <p>
          We've spent years refining our approach to visual storytelling — blending cinematic
          technique with authentic moments. The result is work that feels both polished and real.
        </p>
        <p>
          Based in [Your City], we work with clients locally and worldwide. If you have a story
          to tell, we'd love to hear it.
        </p>
      </div>
    </div>

    <div class="about__cta" data-animate>
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
      <a href="/work" class="btn btn--outline">See the Work</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    padding-top: calc(64px + var(--space-3xl));
    max-width: 700px;
  }

  .about__text {
    margin-top: var(--space-xl);
  }

  .about__text p {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.8;
  }

  .about__text p + p {
    margin-top: var(--space-lg);
  }

  .about__cta {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  .btn {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 14px 28px;
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  .btn--primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn--primary:hover {
    background: #333;
  }

  .btn--outline {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn--outline:hover {
    border-color: var(--color-text);
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustedByCarousel from '../components/home/TrustedByCarousel';
import GlobeSection from '../components/home/GlobeSection';
import MacFileWindow from '../components/ui/mac-file-window';
import { MagneticCTA } from '../components/ui/magnetic-cta';
import { TextReveal } from '../components/ui/text-reveal';
import { BackgroundMesh } from '../components/ui/background-paper-shaders';
---

<BaseLayout title="About" description="Meet the team behind Duddcash — video & photo production for brands, artists, and events.">
  <MacFileWindow client:load />

  <section class="about section">
    <div class="about__inner">
      <div class="about__header" data-animate>
        <p class="label">About Us</p>
        <h1>We're the production team<br />brands actually want to work with <span class="about__again">again</span>.</h1>
      </div>

      <div class="about__body" data-animate>
        <div class="about__text">
          <p>
            Duddcash is a video and photography production company founded by Anthony and Calo.
            We started shooting events and nightlife — and we still do — but the work grew into
            something bigger. Today we produce social content, commercial campaigns, music videos,
            and brand activations for clients like Mastercard, Chipotle, Lululemon, PrizePicks,
            and Wynn.
          </p>
          <p>
            We're young, we move fast, and we don't overcomplicate things. Our clients come back
            because the work is sharp, the turnarounds are real, and we're easy to be in a room with.
            No ego, no fluff — just good creative that performs.
          </p>
          <p>
            Beyond client work, we mentor a growing team of creatives and lead projects from
            concept through delivery. Whether it's a same-day social edit or a multi-day commercial
            shoot, the standard doesn't change.
          </p>
        </div>

        <div class="about__stats-wrap">
          <div class="about__stats-blob"></div>
          <!-- Floating squares -->
          <div class="about__float about__float--1"></div>
          <div class="about__float about__float--2"></div>
          <div class="about__float about__float--3"></div>
          <div class="about__stats">
            <div class="stat">
              <span class="stat__number">15+</span>
              <span class="stat__label">Brand Partners</span>
            </div>
            <div class="stat">
              <span class="stat__number">500+</span>
              <span class="stat__label">Projects Delivered</span>
            </div>
            <div class="stat">
              <span class="stat__number">100%</span>
              <span class="stat__label">Repeat Client Rate</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Globe -->
  <GlobeSection client:visible />

  <!-- Trusted By -->
  <TrustedByCarousel client:visible />

  <!-- Ready to Work — bordered container -->
  <section class="about-cta-section">
    <div class="about-cta-card">
      <div class="about-cta-card__border"></div>
      <div class="about-cta-card__inner">
        <!-- Shader background -->
        <div class="about-cta-card__shader">
          <BackgroundMesh
            client:visible
            speed={0.2}
            colors={["#e8e4dc", "#d4cfc6", "#c8c0b4", "#ddd8cf"]}
            style={{ position: "absolute", inset: 0, width: "100%", height: "100%" }}
          />
        </div>

        <!-- Grid overlay -->
        <svg class="about-cta-card__grid" width="100%" height="100%">
          <defs>
            <pattern id="cta-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#cta-grid)" />
        </svg>

        <!-- Content -->
        <div class="about-cta-card__content" data-animate>
          <TextReveal
            client:visible
            text="Ready to work together?"
            staggerDelay={0.1}
            initialDelay={0.1}
            style={{
              fontFamily: "var(--font-display)",
              fontSize: "clamp(2rem, 4.5vw, 3.5rem)",
              fontWeight: 500,
              letterSpacing: "-0.025em",
              lineHeight: 1.1,
              color: "var(--color-text)",
            }}
          />
          <p class="about-cta-card__sub">No fluff. Just sharp creative, fast turnarounds, and work that speaks.</p>
          <div class="about-cta-card__buttons">
            <MagneticCTA client:visible href="/contact">Start a Project</MagneticCTA>
            <MagneticCTA client:visible href="/#portfolio">See the Work</MagneticCTA>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    padding-top: clamp(4rem, 8vh, 7rem);
    padding-bottom: clamp(3rem, 6vh, 5rem);
  }

  .about__inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 clamp(2rem, 6vw, 7rem);
  }

  .about__header {
    margin-bottom: clamp(3rem, 5vh, 5rem);
  }

  .about__header h1 {
    max-width: 820px;
    margin-top: var(--space-md);
  }

  /* "again" — ink underline draw */
  .about__again {
    position: relative;
    display: inline-block;
    font-style: italic;
  }

  .about__again::after {
    content: '';
    position: absolute;
    bottom: 0.04em;
    left: -2%;
    width: 0%;
    height: 0.08em;
    background: var(--color-text);
    border-radius: 0.04em;
    animation: drawUnderline 1s cubic-bezier(0.65, 0, 0.35, 1) 0.8s forwards;
  }

  @keyframes drawUnderline {
    0% { width: 0%; left: -2%; }
    100% { width: 104%; left: -2%; }
  }

  .about__body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  @media (max-width: 768px) {
    .about__body {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  .about__text p {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .about__text p + p {
    margin-top: var(--space-lg);
  }

  /* Stats with blob */
  .about__stats-wrap {
    position: relative;
    padding: clamp(2rem, 3vw, 3rem);
  }

  .about__stats-blob {
    position: absolute;
    inset: -20px;
    border-radius: 50% 40% 45% 50% / 45% 50% 40% 50%;
    background: radial-gradient(
      ellipse at 40% 30%,
      rgba(200, 190, 170, 0.25) 0%,
      rgba(180, 175, 165, 0.15) 40%,
      rgba(170, 180, 190, 0.1) 70%,
      transparent 100%
    );
    filter: blur(20px);
    animation: blobMorph 12s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes blobMorph {
    0%, 100% { border-radius: 50% 40% 45% 50% / 45% 50% 40% 50%; transform: scale(1); }
    33% { border-radius: 40% 50% 50% 42% / 50% 42% 48% 50%; transform: scale(1.03); }
    66% { border-radius: 45% 42% 40% 50% / 42% 50% 50% 45%; transform: scale(0.97); }
  }

  /* Floating icon squares */
  .about__float {
    position: absolute;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(8px);
    z-index: 0;
  }

  .about__float--1 {
    width: 44px;
    height: 44px;
    top: -18px;
    right: -12px;
    animation: floatSquare1 8s ease-in-out infinite;
  }

  .about__float--2 {
    width: 32px;
    height: 32px;
    bottom: 20px;
    left: -24px;
    border-radius: 10px;
    animation: floatSquare2 10s ease-in-out infinite;
  }

  .about__float--3 {
    width: 24px;
    height: 24px;
    top: 45%;
    right: -30px;
    border-radius: 8px;
    animation: floatSquare3 12s ease-in-out infinite;
  }

  @keyframes floatSquare1 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(8deg); }
  }

  @keyframes floatSquare2 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(10px) rotate(-6deg); }
  }

  @keyframes floatSquare3 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-8px) rotate(12deg); }
    66% { transform: translateY(6px) rotate(-4deg); }
  }

  .about__stats {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .stat__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat__label {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  /* CTA Section */
  .about-cta-section {
    padding: clamp(3rem, 6vh, 6rem) clamp(1.5rem, 4vw, 4rem) clamp(4rem, 8vh, 8rem);
  }

  /* Bordered card container */
  .about-cta-card {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .about-cta-card__border {
    position: absolute;
    inset: -1px;
    border-radius: 24px;
    background: linear-gradient(
      160deg,
      rgba(0, 0, 0, 0.08) 0%,
      rgba(0, 0, 0, 0.03) 30%,
      rgba(160, 150, 130, 0.15) 50%,
      rgba(0, 0, 0, 0.03) 70%,
      rgba(0, 0, 0, 0.08) 100%
    );
    z-index: 0;
  }

  .about-cta-card__inner {
    position: relative;
    z-index: 1;
    border-radius: 23px;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5rem) clamp(2rem, 5vw, 5rem);
  }

  /* Shader bg layer */
  .about-cta-card__shader {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.5;
  }

  /* Grid overlay */
  .about-cta-card__grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    color: var(--color-muted);
    opacity: 0.06;
    pointer-events: none;
  }

  /* Content */
  .about-cta-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-cta-card__sub {
    color: var(--color-muted);
    font-size: var(--text-base);
    line-height: 1.6;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xl);
    max-width: 440px;
    font-style: italic;
  }

  .about-cta-card__buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
  }

  @media (max-width: 480px) {
    .about-cta-card__inner {
      padding: 2.5rem 1.5rem;
      border-radius: 18px;
    }

    .about-cta-card__border {
      border-radius: 19px;
    }

    .about-cta-card__buttons {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
